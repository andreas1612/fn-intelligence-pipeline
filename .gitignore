# Python
__pycache__/
*.pyc
.venv/
venv/

# Environment and secrets (never commit these)
.env
*.env

# Local tooling
.claude/
.pytest_cache/

# Delivered digests (D-024). Not committed: they rebuild from the database at any
# time, and the match ledger already records what was sent and when (delivered_at),
# so committing them would add churn without adding an audit trail.
data/

# OS noise
Thumbs.db
Desktop.ini

# Note: finalogic.db is intentionally NOT ignored.
# The database is the system of record and is committed by the Actions workflow (D-008).
