# Copy to .env and fill in. .env is gitignored and must never be committed.
# In GitHub Actions these are repository secrets with the same names.

# Triage provider: kie.ai (D-026). Models are served through a Gemini-compatible
# API. Get a key at https://kie.ai.
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai

# Model slug from your kie.ai market. Swap it here, not in code.
KIE_MODEL=gemini-3-5-flash

# Thinking effort: low (cheap, default) or high.
KIE_THINKING_LEVEL=low

# Notion review board (the human gate).
NOTION_API_KEY=
NOTION_DATABASE_ID=
